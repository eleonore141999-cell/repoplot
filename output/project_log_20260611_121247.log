"            panel.grid.major.x = element_blank())", "    log_info(\"Finalizing visualization with theme and labels\")", "    log_info(\"Displaying final plot\")", "    print(plot_final3)", "    log_info(\"Saving plot to output/medication_circular_barplot.png\")", "    ggsave(\"output/medication_circular_barplot.png\", plot_final3, ", "        width = 9, height = 12.6)", "    log_success(\"Circular barplot created and saved successfully!\")", "}, error = function(e) {", "    log_error(\"Error during visualization: {e$message}\")", 
